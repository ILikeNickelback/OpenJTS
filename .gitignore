# pixi environments
.pixi/*
!.pixi/config.toml

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# Ruff linter cache
.ruff_cache/

# Pytest cache
.pytest_cache/

# Sphinx: autosummary stubs and build output are regenerated each build
docs/api/
docs/_build/

.claude/

# Runtime experiment data (autosave + raw acquisition dumps), regenerated per run
software/src/temp/
